<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Tiêu đề đăng ký -->
    <TextView
        android:id="@+id/tvRegisterTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Đăng ký liền tay - nhận ngay ưu đãi"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Banner voucher với hình con vật -->
    <LinearLayout
        android:id="@+id/llVoucher"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvRegisterTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgAnimal"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_cute_animal"
            android:scaleType="fitCenter"
            android:contentDescription="Ảnh con vật dễ thương"/>

        <TextView
            android:id="@+id/tvVoucher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Nhận ngay voucher Parkway và bTaskee sau khi đăng ký thành công"
            android:textSize="14sp"
            android:textColor="#000000"
            android:gravity="start"
            android:layout_weight="1"/>
    </LinearLayout>

    <!-- Form đăng ký -->
    <LinearLayout
        android:id="@+id/llForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/llVoucher"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/edtPhone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Số điện thoại"
            android:inputType="phone"
            android:padding="12dp"
            android:background="@drawable/bg_edittext"/>

        <EditText
            android:id="@+id/edtUsername"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Tên đăng nhập"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:background="@drawable/bg_edittext"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/edtPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Mật khẩu"
            android:inputType="textPassword"
            android:padding="12dp"
            android:background="@drawable/bg_edittext"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:background="@drawable/bg_edittext"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Đăng ký"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF6200EE"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

    <!-- Icon social -->
    <LinearLayout
        android:id="@+id/llSocial"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/llForm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnGoogle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_google"
            android:scaleType="fitCenter"
            android:contentDescription="Đăng ký bằng Google"/>

        <ImageView
            android:id="@+id/btnFacebook"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_facebook"
            android:scaleType="fitCenter"
            android:contentDescription="Đăng ký bằng Facebook"/>

        <ImageView
            android:id="@+id/btnZalo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_zalo"
            android:scaleType="fitCenter"
            android:contentDescription="Đăng ký bằng Zalo"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>